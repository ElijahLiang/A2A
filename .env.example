# ===== 通用 =====
NODE_ENV=development
LOG_LEVEL=debug

# ===== 数据库 =====
DATABASE_URL=postgresql://a2a:dev_password@localhost:5432/a2a_dev
DATABASE_POOL_SIZE=20

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
JWT_PRIVATE_KEY=<your-rsa-private-key>
JWT_PUBLIC_KEY=<your-rsa-public-key>
JWT_ACCESS_TOKEN_TTL=7200
JWT_REFRESH_TOKEN_TTL=2592000

# ===== 短信 =====
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=<your-key>
SMS_ACCESS_KEY_SECRET=<your-secret>
SMS_SIGN_NAME=A2A
SMS_TEMPLATE_CODE=<your-template>

# ===== LLM =====
OPENAI_API_KEY=<your-openai-key>
OPENAI_MODEL=gpt-4o
DEEPSEEK_API_KEY=<your-deepseek-key>
DEEPSEEK_MODEL=deepseek-chat
LLM_MAX_TOKENS_PER_REQUEST=2000
LLM_DAILY_BUDGET_USD=50

# ===== 对象存储 =====
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=a2a
OSS_SECRET_KEY=dev_password
OSS_BUCKET=a2a-assets

# ===== 地图 =====
AMAP_API_KEY=<your-amap-key>

# ===== 监控 =====
SENTRY_DSN=<your-sentry-dsn>
